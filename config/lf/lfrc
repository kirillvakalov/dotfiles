set hidden
set info size
set nopreview

# Use $EDITOR to open text files
cmd open &{{
    case $(file --mime-type -Lb $f) in
        text/*) lf -remote "send $id \$$EDITOR \$fx";;
        *) for f in $fx; do $OPENER $f > /dev/null 2> /dev/null & done;;
    esac
}}

map <esc> clear

cmd trash %trash $fx
map d trash

map c cut
